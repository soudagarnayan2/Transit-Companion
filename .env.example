# ============================================================
# Trassit Companion — Environment Variables
# Copy this file to .env and fill in your credentials.
# ============================================================

# --- data.gov.in ---
DATAGOV_API_KEY=your_data_gov_in_api_key

# --- Transit.land ---
TRANSITLAND_API_KEY=your_transitland_api_key

# --- MapMyIndia / Mappls ---
MAPMYINDIA_CLIENT_ID=your_mappls_client_id
MAPMYINDIA_CLIENT_SECRET=your_mappls_client_secret

# --- X / Twitter API v2 ---
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# --- Chalo (if public API access is available) ---
CHALO_API_BASE_URL=https://api.chalo.com

# --- Google Maps (reference validation only) ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================================
# Phase 1A — Database Infrastructure
# ============================================================

# --- PostgreSQL (matches docker-compose defaults) ---
PGHOST=localhost
PGPORT=5432
PGUSER=trassit
PGPASSWORD=trassit_dev
PGDATABASE=trassit_db
PG_POOL_MAX=10

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=          # uncomment if using auth
# REDIS_URL=               # alternative: full connection URL
REDIS_DB=0

# ============================================================
# Phase 4 — AI & Predictions
# ============================================================
GROQ_API_KEY=your_groq_api_key


