{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://YOUR_RAILWAY_APP_URL/api/v1/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RAILWAY_APP_URL/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/src/phase1_realtime/subphase_1e_map_ui/public/$1"
    }
  ]
}
